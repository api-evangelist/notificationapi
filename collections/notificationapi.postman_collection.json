      "item": [
        {
          "id": "a1000000-0000-4000-8000-000000000010",
          "name": "Send a notification",
          "request": {
            "name": "Send a notification",
            "description": {
              "content": "Send a notification to a user across the channels configured for the notification type. Pass an ISO 8601 schedule to schedule for later.",
              "type": "text/plain"
            },
            "url": {
              "raw": "{{baseUrl}}/sender",
              "path": ["sender"],
              "host": ["{{baseUrl}}"],
              "query": [],
              "variable": []
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"order_shipped\",\n  \"to\": {\n    \"id\": \"user_123\",\n    \"email\": \"jane@example.com\",\n    \"number\": \"+15005550006\"\n  },\n  \"parameters\": {\n    \"orderNumber\": \"1043\",\n    \"trackingUrl\": \"https://example.com/track/1043\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [
            {
              "id": "a1000000-0000-4000-8000-000000000011",
              "name": "OK",
              "originalRequest": {
                "url": {
                  "raw": "{{baseUrl}}/sender",
                  "path": ["sender"],
                  "host": ["{{baseUrl}}"]
                },
                "method": "POST",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"type\": \"order_shipped\",\n  \"to\": { \"id\": \"user_123\", \"email\": \"jane@example.com\" }\n}"
                }
              },
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"trackingId\": \"3f9c1b2a-7d4e-4a0b-9f21-8c6e2d1a0b34\"\n}",
              "cookie": [],
              "_postman_previewlanguage": "json"
            }
          ],
          "event": []
        },
